---
import SectionTitle from './ui/SectionTitle.jsx';
import { SEO_PAGES } from '../data/seoPages.js';

const { currentPath = '' } = Astro.props;
const seoPages = SEO_PAGES.filter((page) => page.path !== currentPath);
---

<section class="bg-light-alt py-16 sm:py-20">
  <div class="container mx-auto px-6 sm:px-8 lg:px-10">
    <div class="scroll-reveal">
      <SectionTitle
        title="Recursos y consultas especializadas"
        subtitle="Accede a páginas pensadas para búsquedas locales y temas clave de atención psiquiátrica."
      />
    </div>

    <div class="grid gap-6 md:grid-cols-3">
      {seoPages.map((page, index) => (
        <a
          href={page.path}
          class={`group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-lg scroll-reveal stagger-${(index % 6) + 1}`}
        >
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-accent">Guía local</p>
          <h3 class="mt-3 font-heading text-2xl font-semibold tracking-tight text-slate-900">
            {page.linkTitle}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{page.excerpt}</p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary transition-transform duration-300 group-hover:translate-x-1">
            Ver página
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14"></path>
              <path d="m12 5 7 7-7 7"></path>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
