---
import { BRAND_INFO, NAV_LINKS, UI_TEXT } from '../../data/content';
---

<nav
  id="site-nav"
  data-navbar
  class="fixed top-0 z-40 w-full bg-primary py-4 transition-all duration-300"
>
  <div class="container mx-auto flex items-center justify-between px-6 text-white">
    <a href="/" class="flex items-center gap-3 group" aria-label={`${BRAND_INFO.name} inicio`}>
      <img
        src="/images/LogoGaleneOscuro.svg"
        alt="Logotipo de Galene"
        class="h-10 w-auto object-contain transition-transform duration-300 group-hover:scale-105"
        width="216"
        height="40"
        decoding="async"
      />
      <span class="sr-only">{`${BRAND_INFO.name} - ${BRAND_INFO.tagline}`}</span>
    </a>

    <div class="hidden items-center gap-6 font-body text-sm font-medium md:flex">
      {NAV_LINKS.map((item) => (
        <a
          href={item.href.startsWith('#') ? `/${item.href}` : item.href}
          class="group relative py-1 text-white/90 transition-colors hover:text-white"
          aria-label={`Ir a la sección ${item.label}`}
        >
          {item.label}
          <span class="absolute bottom-0 left-0 h-0.5 w-0 bg-secondary transition-all duration-300 group-hover:w-full" />
        </a>
      ))}
      <a
        href={BRAND_INFO.whatsappLink}
        target="_blank"
        rel="noreferrer"
        class="ml-2 flex items-center gap-2 rounded-full bg-gradient-to-r from-secondary to-accent px-5 py-2.5 text-sm font-semibold text-white transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-secondary/30 hover-shine"
        aria-label="Agendar cita por WhatsApp"
      >
        <svg
          aria-hidden="true"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
        </svg>
        {UI_TEXT.navCta}
        <svg
          aria-hidden="true"
          class="ml-1 h-3.5 w-3.5 transition-transform group-hover:translate-x-1"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <button
      type="button"
      class="rounded-lg bg-white/10 p-2 text-white transition-colors hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-secondary md:hidden"
      aria-label="Abrir menú móvil"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-toggle
    >
      <svg
        data-menu-icon
        aria-hidden="true"
        class="h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="4" x2="20" y1="12" y2="12"></line>
        <line x1="4" x2="20" y1="6" y2="6"></line>
        <line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
      <svg
        data-close-icon
        aria-hidden="true"
        class="hidden h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    data-mobile-menu
    class="absolute left-0 top-full hidden w-full bg-gradient-to-b from-primary to-primary/95 text-white shadow-2xl backdrop-blur-md md:hidden"
  >
    <div class="container mx-auto flex flex-col gap-1 px-6 py-6">
      {NAV_LINKS.map((item, index) => (
        <a
          href={item.href.startsWith('#') ? `/${item.href}` : item.href}
          class="flex items-center gap-3 rounded-xl px-4 py-3 text-lg text-white/90 transition-all duration-200 hover:bg-white/10 hover:text-white"
          aria-label={`Ir a la sección ${item.label}`}
          data-mobile-link
          style={`animation-delay: ${index * 50}ms;`}
        >
          <span class="h-1.5 w-1.5 rounded-full bg-secondary" />
          {item.label}
        </a>
      ))}

      <div class="my-3 border-t border-white/10" />

      <div class="space-y-3 px-4 py-2 text-sm text-white/70">
        <div class="flex items-center gap-3">
          <svg
            aria-hidden="true"
            class="h-4 w-4 text-secondary"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.08 4.18 2 2 0 0 1 4.06 2h3a2 2 0 0 1 2 1.72c.12.9.34 1.78.65 2.62a2 2 0 0 1-.45 2.11L8 9.91a16 16 0 0 0 6 6l1.46-1.26a2 2 0 0 1 2.11-.45c.84.31 1.72.53 2.62.65A2 2 0 0 1 22 16.92z"></path>
          </svg>
          <span>{BRAND_INFO.phone}</span>
        </div>
        <div class="flex items-center gap-3">
          <svg
            aria-hidden="true"
            class="h-4 w-4 text-secondary"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <span>Lun - Sáb: 9am - 8pm</span>
        </div>
      </div>

      <a
        href={BRAND_INFO.whatsappLink}
        target="_blank"
        rel="noreferrer"
        class="mt-4 flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-secondary to-accent py-3.5 text-center font-semibold text-white shadow-lg transition-all hover:shadow-secondary/30"
        data-mobile-link
      >
        <svg
          aria-hidden="true"
          class="h-4.5 w-4.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
        </svg>
        Agendar por WhatsApp
        <svg
          aria-hidden="true"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"></path>
          <path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</nav>

<script is:inline>
  (() => {
    const nav = document.querySelector('[data-navbar]');
    const toggle = nav?.querySelector('[data-menu-toggle]');
    const menu = nav?.querySelector('[data-mobile-menu]');
    const menuIcon = nav?.querySelector('[data-menu-icon]');
    const closeIcon = nav?.querySelector('[data-close-icon]');
    const closeTargets = nav?.querySelectorAll('[data-mobile-link]');

    if (!nav || !toggle || !menu || !menuIcon || !closeIcon) return;

    let isOpen = false;
    let rafId = 0;

    const syncScrollState = () => {
      const scrolled = window.scrollY > 50;
      nav.classList.toggle('bg-primary/95', scrolled);
      nav.classList.toggle('backdrop-blur-md', scrolled);
      nav.classList.toggle('shadow-lg', scrolled);
      nav.classList.toggle('py-2', scrolled);
      nav.classList.toggle('bg-primary', !scrolled);
      nav.classList.toggle('py-4', !scrolled);
    };

    const setMenuState = (nextOpen) => {
      isOpen = nextOpen;
      toggle.setAttribute('aria-expanded', String(nextOpen));
      toggle.setAttribute('aria-label', nextOpen ? 'Cerrar menú móvil' : 'Abrir menú móvil');
      menu.classList.toggle('hidden', !nextOpen);
      menuIcon.classList.toggle('hidden', nextOpen);
      closeIcon.classList.toggle('hidden', !nextOpen);
      document.body.classList.toggle('overflow-hidden', nextOpen);
    };

    toggle.addEventListener('click', () => setMenuState(!isOpen));

    closeTargets?.forEach((link) => {
      link.addEventListener('click', () => setMenuState(false));
    });

    window.addEventListener(
      'scroll',
      () => {
        if (rafId) return;
        rafId = window.requestAnimationFrame(() => {
          rafId = 0;
          syncScrollState();
        });
      },
      { passive: true }
    );

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) setMenuState(false);
      syncScrollState();
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && isOpen) setMenuState(false);
    });

    syncScrollState();
  })();
</script>
